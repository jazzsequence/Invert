    "remark": "^15.0.0",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.0",
    "wrangler": "^4.80.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "overrides": {
